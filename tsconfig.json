{
	"compilerOptions": {
		/* Language and Environment */
		"target": "es2021",
		"lib": ["es2021"],
		"jsx": "react-jsx",

		/* Modules */
		"module": "es2022",
		"moduleResolution": "Bundler",
		"resolveJsonModule": true,
		"types": ["@cloudflare/workers-types"],

		/* Emit */
		"isolatedModules": true,

		/* Interop Constraints */
		"forceConsistentCasingInFileNames": true,

		/* Type Checking */
		"strict": true,
		"skipLibCheck": true
	},
	"include": ["worker-configuration.d.ts", "src/**/*.ts"],
	"exclude": ["test"]
}
