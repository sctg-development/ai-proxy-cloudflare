{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ai-proxy-cloudflare",
  "main": "src/index.ts",
  "compatibility_date": "2024-12-13",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "define": {
    "import.meta.url": "'file:///worker/index.js'"
  },
  "alias": {
    "@ai-sdk/amazon-bedrock": "./src/lib/stubs/unavailable-provider.cjs",
    "@aws-sdk/credential-providers": "./src/lib/stubs/unavailable-provider.cjs",
    "@ai-sdk/google-vertex": "./src/lib/stubs/unavailable-provider.cjs",
    "@ai-sdk/google-vertex/anthropic": "./src/lib/stubs/unavailable-provider.cjs",
    "@jerome-benoit/sap-ai-provider": "./src/lib/stubs/unavailable-provider.cjs",
    "@langfuse/otel": "./src/lib/stubs/unavailable-provider.cjs",
    "@opentelemetry/sdk-trace-node": "./src/lib/stubs/unavailable-provider.cjs",
    "ai-sdk-provider-claude-code": "./src/lib/stubs/unavailable-provider.cjs",
    "ai-sdk-provider-codex-cli": "./src/lib/stubs/unavailable-provider.cjs",
    "ai-sdk-provider-opencode-sdk": "./src/lib/stubs/unavailable-provider.cjs",
    "dify-ai-provider": "./src/lib/stubs/unavailable-provider.cjs"
  },
  "vars": {
    "DEBUG": "false",
    "FUFUNI_MERCHANT_URL": ""
  },
  "kv_namespaces": [
    {
      "binding": "KV_AI_PROXY",
      "id": "0f6936bc4d9b4d5fa1cc85acd757e354"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "USAGE_DO",
        "class_name": "UsageDbDurableObject"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1_usage_do_sqlite",
      "new_sqlite_classes": ["UsageDbDurableObject"]
    }
  ],
  "ratelimits": [
    {
      "name": "PROXY_RATE_LIMITER",
      "namespace_id": "1001",
      "simple": {
        "limit": 10,
        "period": 60
      }
    }
  ],
  "observability": {
    "enabled": true
  }
}